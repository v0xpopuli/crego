app_env: development

server:
  port: {{ .Recipe.Server.Port }}

logging:
  format: {{ .Recipe.Logging.Format }}

{{ if anyDatabaseEnabled }}
database:
{{ if hasDatabase "postgres" }}
  postgres:
    user-name: "postgres"
    password: "postgres"
    host: "localhost:5432"
    database: "app"
    ssl-mode: ""
{{ if sqlMigrations .Recipe.Database.Migrations }}    migrations: file://scripts/migrations
{{ end }}    max-open-connections: 10
    max-idle-connections: 5
{{ end -}}
{{ if hasDatabase "mysql" }}
  mysql:
    user-name: "root"
    password: "root"
    host: "localhost:3306"
    database: "app"
    parse-time: true
{{ if sqlMigrations .Recipe.Database.Migrations }}    migrations: file://scripts/migrations
{{ end }}    max-open-connections: 10
    max-idle-connections: 5
{{ end -}}
{{ if hasDatabase "sqlite" }}
  sqlite:
    path: "app.db"
    foreign-keys: true
{{ if sqlMigrations .Recipe.Database.Migrations }}    migrations: file://scripts/migrations
{{ end }}    max-open-connections: 1
    max-idle-connections: 1
{{ end -}}
{{ if hasDatabase "redis" }}
  redis:
    host: "localhost:6379"
    password: ""
    database: 0
{{ end -}}
{{ if hasDatabase "mongodb" }}
  mongodb:
    user-name: ""
    password: ""
    host: "localhost:27017"
    database: "app"
{{ end -}}
{{ end -}}
{{ if schedulerEnabled }}
task_scheduler:
  worker: crego-task-executor
  tasks:
    example_cleanup:
      name: example-cleanup
      cron: "0 2 * * *"
      should_start_immediately: false
      batch_size: 500
      retention_period: 72h
{{ end -}}
