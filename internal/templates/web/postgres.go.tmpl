{{ if eq .Recipe.Layout.Style "minimal" -}}
package app
{{ else -}}
package database
{{ end }}

import (
	"context"
{{ if or (eq .Recipe.Database.Framework "sql") (eq .Recipe.Database.Framework "gorm") }}
	"database/sql"
{{ end }}
	"fmt"
{{ if or (eq .Recipe.Database.Framework "sql") (eq .Recipe.Database.Framework "gorm") }}
	"time"
{{ end }}

{{ if eq .Recipe.Database.Framework "pgx" }}
	"github.com/jackc/pgx/v5/pgxpool"
{{ end }}
{{ if eq .Recipe.Database.Framework "sql" }}
	_ "github.com/jackc/pgx/v5/stdlib"
{{ end }}
{{ if eq .Recipe.Database.Framework "gorm" }}
	"gorm.io/driver/postgres"
	"gorm.io/gorm"
{{ end }}
{{ if ne .Recipe.Layout.Style "minimal" }}
	"{{ .ModulePath }}/internal/config"
	"{{ .ModulePath }}/internal/logging"
{{ end -}}
)

type PostgresClient struct {
	config {{ if eq .Recipe.Layout.Style "minimal" }}PostgresConfig{{ else }}config.PostgresConfig{{ end }}
	address string
	logger  {{ if eq .Recipe.Layout.Style "minimal" }}Logger{{ else }}logging.Logger{{ end }}
{{ if eq .Recipe.Database.Framework "pgx" }}
	Pool *pgxpool.Pool
{{ end }}
{{ if eq .Recipe.Database.Framework "sql" }}
	DB *sql.DB
{{ end }}
{{ if eq .Recipe.Database.Framework "gorm" }}
	Database *gorm.DB
	sqlDB    *sql.DB
{{ end }}
}

func NewPostgresClient(ctx context.Context, cfg {{ if eq .Recipe.Layout.Style "minimal" }}PostgresConfig{{ else }}config.PostgresConfig{{ end }}, logger {{ if eq .Recipe.Layout.Style "minimal" }}Logger{{ else }}logging.Logger{{ end }}) (*PostgresClient, error) {
	address := postgresAddress(cfg)
{{ if eq .Recipe.Database.Framework "pgx" }}
	poolConfig, err := pgxpool.ParseConfig(address)
	if err != nil {
		return nil, fmt.Errorf("parse postgres address: %w", err)
	}
	poolConfig.MaxConns = int32(cfg.MaxOpenConnections)
	pool, err := pgxpool.NewWithConfig(ctx, poolConfig)
	if err != nil {
		return nil, fmt.Errorf("open postgres database: %w", err)
	}
	client := &PostgresClient{config: cfg, address: address, logger: logger, Pool: pool}
	if err := client.Ping(ctx); err != nil {
		pool.Close()
		return nil, fmt.Errorf("ping postgres database: %w", err)
	}
{{ end }}
{{ if eq .Recipe.Database.Framework "sql" }}
	db, err := sql.Open("pgx", address)
	if err != nil {
		return nil, fmt.Errorf("open postgres database: %w", err)
	}
	db.SetMaxOpenConns(cfg.MaxOpenConnections)
	db.SetMaxIdleConns(cfg.MaxIdleConnections)
	db.SetConnMaxLifetime(30 * time.Minute)
	client := &PostgresClient{config: cfg, address: address, logger: logger, DB: db}
	if err := client.Ping(ctx); err != nil {
		_ = db.Close()
		return nil, fmt.Errorf("ping postgres database: %w", err)
	}
{{ end }}
{{ if eq .Recipe.Database.Framework "gorm" }}
	database, err := gorm.Open(postgres.Open(address), &gorm.Config{})
	if err != nil {
		return nil, fmt.Errorf("open postgres database: %w", err)
	}
	sqlDB, err := database.DB()
	if err != nil {
		return nil, fmt.Errorf("open postgres sql database: %w", err)
	}
	sqlDB.SetMaxOpenConns(cfg.MaxOpenConnections)
	sqlDB.SetMaxIdleConns(cfg.MaxIdleConnections)
	sqlDB.SetConnMaxLifetime(30 * time.Minute)
	client := &PostgresClient{config: cfg, address: address, logger: logger, Database: database, sqlDB: sqlDB}
	if err := client.Ping(ctx); err != nil {
		_ = sqlDB.Close()
		return nil, fmt.Errorf("ping postgres database: %w", err)
	}
{{ end }}
	if logger != nil {
		logger.Info("database connected", "driver", "postgres", "framework", "{{ .Recipe.Database.Framework }}")
	}
	return client, nil
}

func (c *PostgresClient) Ping(ctx context.Context) error {
{{ if eq .Recipe.Database.Framework "pgx" }}
	return c.Pool.Ping(ctx)
{{ end }}
{{ if eq .Recipe.Database.Framework "sql" }}
	return c.DB.PingContext(ctx)
{{ end }}
{{ if eq .Recipe.Database.Framework "gorm" }}
	return c.sqlDB.PingContext(ctx)
{{ end }}
}

func (c *PostgresClient) Shutdown(ctx context.Context) error {
{{ if eq .Recipe.Database.Framework "pgx" }}
	_ = ctx
	c.Pool.Close()
{{ end }}
{{ if eq .Recipe.Database.Framework "sql" }}
	if err := c.DB.Close(); err != nil {
		return err
	}
{{ end }}
{{ if eq .Recipe.Database.Framework "gorm" }}
	if err := c.sqlDB.Close(); err != nil {
		return err
	}
{{ end }}
	if c.logger != nil {
		c.logger.Info("database connection closed", "driver", "postgres")
	}
	return nil
}

func postgresAddress(cfg {{ if eq .Recipe.Layout.Style "minimal" }}PostgresConfig{{ else }}config.PostgresConfig{{ end }}) string {
	address := fmt.Sprintf("postgres://%s:%s@%s/%s", cfg.UserName, cfg.Password, cfg.Host, cfg.Database)
	if cfg.SSLMode != "" {
		address += "?sslmode=" + cfg.SSLMode
	}
	return address
}
