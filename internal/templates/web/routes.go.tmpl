{{ if eq .Recipe.Layout.Style "minimal" -}}
package app
{{ else -}}
package server
{{ end }}

{{ if eq .Recipe.Server.Framework "nethttp" -}}
import (
	"net/http"

{{ if ne .Recipe.Layout.Style "minimal" -}}
{{ if or .Recipe.Observability.Health .Recipe.Observability.Readiness -}}
	"{{ .ModulePath }}/internal/server/handler"
{{ end -}}
	"{{ .ModulePath }}/internal/server/middleware"
{{ end -}}
)

func (s *Server) routes() http.Handler {
	mux := http.NewServeMux()
{{ if .Recipe.Observability.Health }}
{{ if eq .Recipe.Layout.Style "minimal" -}}
	mux.HandleFunc("/health", Health)
{{ else -}}
	mux.HandleFunc("/health", handler.Health)
{{ end -}}
{{ end -}}
{{ if .Recipe.Observability.Readiness }}
{{ if eq .Recipe.Layout.Style "minimal" -}}
	mux.HandleFunc("/ready", Ready)
{{ else -}}
	mux.HandleFunc("/ready", handler.Ready)
{{ end -}}
{{ end }}
	var h http.Handler = mux
{{ if eq .Recipe.Layout.Style "minimal" -}}
	h = Logging(s.logger)(h)
	h = RequestID(h)
{{ else -}}
	h = middleware.Logging(s.logger)(h)
	h = middleware.RequestID(h)
{{ end -}}
	return h
}
{{ end -}}
