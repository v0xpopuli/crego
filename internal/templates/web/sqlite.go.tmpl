{{ if eq .Recipe.Layout.Style "minimal" -}}
package app
{{ else -}}
package database
{{ end }}

import (
	"context"
	"database/sql"
	"fmt"
	"time"

{{ if eq .Recipe.Database.Framework "sql" }}
	_ "modernc.org/sqlite"
{{ end }}
{{ if eq .Recipe.Database.Framework "gorm" }}
	"gorm.io/driver/sqlite"
	"gorm.io/gorm"
{{ end }}
{{ if ne .Recipe.Layout.Style "minimal" }}
	"{{ .ModulePath }}/internal/config"
	"{{ .ModulePath }}/internal/logging"
{{ end -}}
)

type SQLiteClient struct {
	config {{ if eq .Recipe.Layout.Style "minimal" }}SQLiteConfig{{ else }}config.SQLiteConfig{{ end }}
	address string
	logger  {{ if eq .Recipe.Layout.Style "minimal" }}Logger{{ else }}logging.Logger{{ end }}
{{ if eq .Recipe.Database.Framework "sql" }}
	DB *sql.DB
{{ end }}
{{ if eq .Recipe.Database.Framework "gorm" }}
	Database *gorm.DB
	sqlDB    *sql.DB
{{ end }}
}

func NewSQLiteClient(ctx context.Context, cfg {{ if eq .Recipe.Layout.Style "minimal" }}SQLiteConfig{{ else }}config.SQLiteConfig{{ end }}, logger {{ if eq .Recipe.Layout.Style "minimal" }}Logger{{ else }}logging.Logger{{ end }}) (*SQLiteClient, error) {
	address := sqliteDSN(cfg)
{{ if eq .Recipe.Database.Framework "sql" }}
	db, err := sql.Open("sqlite", address)
	if err != nil {
		return nil, fmt.Errorf("open sqlite database: %w", err)
	}
	db.SetMaxOpenConns(cfg.MaxOpenConnections)
	db.SetMaxIdleConns(cfg.MaxIdleConnections)
	db.SetConnMaxLifetime(30 * time.Minute)
	client := &SQLiteClient{config: cfg, address: address, logger: logger, DB: db}
	if err := client.Ping(ctx); err != nil {
		_ = db.Close()
		return nil, fmt.Errorf("ping sqlite database: %w", err)
	}
{{ end }}
{{ if eq .Recipe.Database.Framework "gorm" }}
	database, err := gorm.Open(sqlite.Open(address), &gorm.Config{})
	if err != nil {
		return nil, fmt.Errorf("open sqlite database: %w", err)
	}
	sqlDB, err := database.DB()
	if err != nil {
		return nil, fmt.Errorf("open sqlite sql database: %w", err)
	}
	sqlDB.SetMaxOpenConns(cfg.MaxOpenConnections)
	sqlDB.SetMaxIdleConns(cfg.MaxIdleConnections)
	sqlDB.SetConnMaxLifetime(30 * time.Minute)
	client := &SQLiteClient{config: cfg, address: address, logger: logger, Database: database, sqlDB: sqlDB}
	if err := client.Ping(ctx); err != nil {
		_ = sqlDB.Close()
		return nil, fmt.Errorf("ping sqlite database: %w", err)
	}
{{ end }}
	if logger != nil {
		logger.Info("database connected", "driver", "sqlite", "framework", "{{ .Recipe.Database.Framework }}")
	}
	return client, nil
}

func (c *SQLiteClient) Ping(ctx context.Context) error {
{{ if eq .Recipe.Database.Framework "sql" }}
	return c.DB.PingContext(ctx)
{{ end }}
{{ if eq .Recipe.Database.Framework "gorm" }}
	return c.sqlDB.PingContext(ctx)
{{ end }}
}

func (c *SQLiteClient) Shutdown(ctx context.Context) error {
	_ = ctx
{{ if eq .Recipe.Database.Framework "sql" }}
	if err := c.DB.Close(); err != nil {
		return err
	}
{{ end }}
{{ if eq .Recipe.Database.Framework "gorm" }}
	if err := c.sqlDB.Close(); err != nil {
		return err
	}
{{ end }}
	if c.logger != nil {
		c.logger.Info("database connection closed", "driver", "sqlite")
	}
	return nil
}

func sqliteDSN(cfg {{ if eq .Recipe.Layout.Style "minimal" }}SQLiteConfig{{ else }}config.SQLiteConfig{{ end }}) string {
	address := "file:" + cfg.Path
	if cfg.ForeignKeys {
		address += "?_foreign_keys=on"
	}
	return address
}
