{{ if eq .Recipe.Layout.Style "minimal" -}}
package app
{{ else -}}
package handler
{{ end }}

{{ if or (eq .Recipe.Server.Framework "nethttp") (eq .Recipe.Server.Framework "chi") -}}
import "net/http"

func Ready(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		w.WriteHeader(http.StatusMethodNotAllowed)
		return
	}
	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(http.StatusOK)
	_, _ = w.Write([]byte("{\"status\":\"ready\"}\n"))
}
{{ end -}}
{{ if eq .Recipe.Server.Framework "gin" -}}
import (
	"net/http"

	"github.com/gin-gonic/gin"
)

func Ready(c *gin.Context) {
	c.JSON(http.StatusOK, gin.H{"status": "ready"})
}
{{ end -}}
{{ if eq .Recipe.Server.Framework "echo" -}}
import (
	"net/http"

	"github.com/labstack/echo/v4"
)

func Ready(c echo.Context) error {
	return c.JSON(http.StatusOK, map[string]string{"status": "ready"})
}
{{ end -}}
{{ if eq .Recipe.Server.Framework "fiber" -}}
import "github.com/gofiber/fiber/v2"

func Ready(c *fiber.Ctx) error {
	return c.Status(fiber.StatusOK).JSON(fiber.Map{"status": "ready"})
}
{{ end -}}
