{{ if eq .Recipe.Layout.Style "minimal" -}}
package app
{{ else -}}
package config
{{ end }}

import (
{{ if eq .Recipe.Configuration.Format "json" -}}
	"encoding/json"
{{ end -}}
	"fmt"
	"os"
	"strconv"

{{ if eq .Recipe.Configuration.Format "toml" -}}
	"github.com/pelletier/go-toml/v2"
{{ end -}}
{{ if eq .Recipe.Configuration.Format "yaml" -}}
	"gopkg.in/yaml.v3"
{{ end -}}
)

type Config struct {
	AppEnv    string {{ configTag "app_env" }}
	HTTPPort  int    {{ configTag "http_port" }}
	LogFormat string {{ configTag "log_format" }}
{{ if hasDatabase "postgres" }}	PostgresURL string {{ configTag "postgres_url" }}
{{ end }}{{ if hasDatabase "mysql" }}	MySQLURL string {{ configTag "mysql_url" }}
{{ end }}{{ if hasDatabase "sqlite" }}	SQLiteURL string {{ configTag "sqlite_url" }}
{{ end }}{{ if and (anySQLDatabaseEnabled) (sqlMigrations .Recipe.Database.Migrations) }}	DatabaseMigrations string {{ configTag "database_migrations" }}
{{ end }}{{ if hasDatabase "redis" }}	RedisAddress string {{ configTag "redis_address" }}
{{ end }}{{ if hasDatabase "mongodb" }}	MongoDBURI string {{ configTag "mongodb_uri" }}
{{ end -}}
}

type Options struct {
	Path string
}

func LoadConfig(opts Options) (Config, error) {
	cfg := defaultConfig()
{{ if eq .Recipe.Configuration.Format "env" }}
	_ = opts
{{ else }}
	path := resolveConfigPath(opts.Path, "configs/config.{{ .Recipe.Configuration.Format }}")
	data, err := os.ReadFile(path)
	if err != nil {
		return Config{}, fmt.Errorf("read config %q: %w", path, err)
	}
{{ if eq .Recipe.Configuration.Format "json" }}
	if err := json.Unmarshal(data, &cfg); err != nil {
		return Config{}, fmt.Errorf("decode config %q: %w", path, err)
	}
{{ end -}}
{{ if eq .Recipe.Configuration.Format "toml" }}
	if err := toml.Unmarshal(data, &cfg); err != nil {
		return Config{}, fmt.Errorf("decode config %q: %w", path, err)
	}
{{ end -}}
{{ if eq .Recipe.Configuration.Format "yaml" }}
	if err := yaml.Unmarshal(data, &cfg); err != nil {
		return Config{}, fmt.Errorf("decode config %q: %w", path, err)
	}
{{ end -}}
{{ end }}
	if err := applyEnvOverrides(&cfg); err != nil {
		return Config{}, err
	}
	if err := validateConfig(cfg); err != nil {
		return Config{}, err
	}
	return cfg, nil
}

func defaultConfig() Config {
	return Config{
		AppEnv:    "development",
		HTTPPort:  {{ .Recipe.Server.Port }},
		LogFormat: "{{ .Recipe.Logging.Format }}",
{{ if hasDatabase "postgres" }}		PostgresURL: "postgres://postgres:postgres@localhost:5432/app?sslmode=disable",
{{ end }}{{ if hasDatabase "mysql" }}		MySQLURL: "mysql://root:root@tcp(localhost:3306)/app?parseTime=true",
{{ end }}{{ if hasDatabase "sqlite" }}		SQLiteURL: "file:app.db?_foreign_keys=on",
{{ end }}{{ if and (anySQLDatabaseEnabled) (sqlMigrations .Recipe.Database.Migrations) }}		DatabaseMigrations: "file://scripts/migrations",
{{ end }}{{ if hasDatabase "redis" }}		RedisAddress: "localhost:6379",
{{ end }}{{ if hasDatabase "mongodb" }}		MongoDBURI: "mongodb://localhost:27017/app",
{{ end -}}
	}
}
{{ if ne .Recipe.Configuration.Format "env" }}
func resolveConfigPath(explicit string, fallback string) string {
	if explicit != "" {
		return explicit
	}
	if value := os.Getenv("CONFIG_PATH"); value != "" {
		return value
	}
	return fallback
}
{{ end }}
func applyEnvOverrides(cfg *Config) error {
	if value := os.Getenv("APP_ENV"); value != "" {
		cfg.AppEnv = value
	}
	if value := os.Getenv("HTTP_PORT"); value != "" {
		port, err := strconv.Atoi(value)
		if err != nil {
			return fmt.Errorf("parse HTTP_PORT: %w", err)
		}
		cfg.HTTPPort = port
	}
	if value := os.Getenv("LOG_FORMAT"); value != "" {
		cfg.LogFormat = value
	}
{{ if hasDatabase "postgres" }}
	if value := os.Getenv("POSTGRES_URL"); value != "" {
		cfg.PostgresURL = value
	}
{{ end -}}
{{ if hasDatabase "mysql" }}
	if value := os.Getenv("MYSQL_URL"); value != "" {
		cfg.MySQLURL = value
	}
{{ end -}}
{{ if hasDatabase "sqlite" }}
	if value := os.Getenv("SQLITE_URL"); value != "" {
		cfg.SQLiteURL = value
	}
{{ end -}}
{{ if anySQLDatabaseEnabled }}
{{ if sqlMigrations .Recipe.Database.Migrations }}
	if value := os.Getenv("DATABASE_MIGRATIONS"); value != "" {
		cfg.DatabaseMigrations = value
	}
{{ end -}}
{{ end -}}
{{ if hasDatabase "redis" }}
	if value := os.Getenv("REDIS_ADDRESS"); value != "" {
		cfg.RedisAddress = value
	}
{{ end -}}
{{ if hasDatabase "mongodb" }}
	if value := os.Getenv("MONGODB_URI"); value != "" {
		cfg.MongoDBURI = value
	}
{{ end -}}
	return nil
}

func validateConfig(cfg Config) error {
	if cfg.AppEnv == "" {
		return fmt.Errorf("app_env is required")
	}
	if cfg.HTTPPort < 1 || cfg.HTTPPort > 65535 {
		return fmt.Errorf("http_port must be between 1 and 65535")
	}
	if cfg.LogFormat != "text" && cfg.LogFormat != "json" {
		return fmt.Errorf("log_format must be text or json")
	}
{{ if hasDatabase "postgres" }}
	if cfg.PostgresURL == "" {
		return fmt.Errorf("postgres_url is required")
	}
{{ end -}}
{{ if hasDatabase "mysql" }}
	if cfg.MySQLURL == "" {
		return fmt.Errorf("mysql_url is required")
	}
{{ end -}}
{{ if hasDatabase "sqlite" }}
	if cfg.SQLiteURL == "" {
		return fmt.Errorf("sqlite_url is required")
	}
{{ end -}}
{{ if anySQLDatabaseEnabled }}
{{ if sqlMigrations .Recipe.Database.Migrations }}
	if cfg.DatabaseMigrations == "" {
		return fmt.Errorf("database_migrations is required")
	}
{{ end -}}
{{ end -}}
{{ if hasDatabase "redis" }}
	if cfg.RedisAddress == "" {
		return fmt.Errorf("redis_address is required")
	}
{{ end -}}
{{ if hasDatabase "mongodb" }}
	if cfg.MongoDBURI == "" {
		return fmt.Errorf("mongodb_uri is required")
	}
{{ end -}}
	return nil
}
